    "prettier:check": "prettier --check ."
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/cli-defaults": "^0.1.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.0",
    "typescript": "~5.8.0"
  },
  "prettier": "@backstage/cli/config/prettier"
}
